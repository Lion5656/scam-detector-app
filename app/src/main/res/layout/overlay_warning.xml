<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#99000000">

    <!-- Warning Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="32dp"
        android:background="@drawable/card_round"
        android:elevation="12dp"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Top Header: Icon and Label -->
        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="center"
            android:src="@drawable/outline_shield_person_24"
            app:tint="@color/overlay_icon_gold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif-medium"
            android:text="Security &amp; Privacy"
            android:textColor="@color/overlay_icon_gold"
            android:textSize="12sp" />

        <!-- Title -->
        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:fontFamily="sans-serif-medium"
            android:text="防詐安全警告"
            android:textColor="@color/overlay_text_primary"
            android:textSize="22sp" />

        <!-- Description -->
        <TextView
            android:id="@+id/description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.2"
            android:text="目前通話號碼為陌生來電，可能試圖透過通話誘導您操作金融帳戶，為了您的安全，建議立即中止通話。"
            android:textColor="@color/overlay_text_secondary"
            android:textSize="14sp" />

        <!-- Instruction List -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical">

            <!-- Item 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/outline_question_mark_24"
                    app:tint="@color/overlay_text_primary" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="不要輕信陌生來電的身份"
                    android:textColor="@color/overlay_text_primary"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Item 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/outline_chat_info_24"
                    app:tint="@color/overlay_text_primary" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="不要遵從陌生來電的指示"
                    android:textColor="@color/overlay_text_primary"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Item 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/round_money_off_24"
                    app:tint="@color/overlay_text_primary" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="不要分享個人或金融資訊"
                    android:textColor="@color/overlay_text_primary"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- EndCall Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/endCall"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:fontFamily="sans-serif-medium"
            android:text="@string/btn_end_call"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            app:backgroundTint="@color/overlay_button_red"
            app:cornerRadius="28dp"
            app:icon="@android:drawable/ic_menu_call"
            app:iconGravity="textStart"
            app:iconTint="@color/white"
            app:iconPadding="8dp" />

        <!-- Continue Button with Countdown -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/countdown"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:text=""
            android:backgroundTint="@android:color/white"
            app:cornerRadius="28dp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/overlay_text_secondary"
            android:textSize="14sp" />

    </LinearLayout>
</FrameLayout>
